# Virtual environment
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Generated icon (regenerated by the installer)
assets/icon.png
assets/icon.ico

# Saved acquisition output (keep the folder, ignore contents)
saved_data/*
!saved_data/.gitkeep

# Offline wheel bundle (large, platform-specific; built by prepare_offline)
vendor/wheels/*
!vendor/wheels/.gitkeep

# OS
.DS_Store
Thumbs.db
